<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Dark Ollama Palette — inspired by ollama.com dark surfaces -->
    <Color x:Key="Canvas">#0D1117</Color>
    <Color x:Key="Surface">#161B22</Color>
    <Color x:Key="SurfaceSoft">#1C2128</Color>
    <Color x:Key="Hairline">#21262D</Color>
    <Color x:Key="HairlineStrong">#30363D</Color>

    <Color x:Key="OnCanvas">#FFFFFF</Color>
    <Color x:Key="OnCanvasMute">#B3FFFFFF</Color>
    <Color x:Key="Body">#8B949E</Color>
    <Color x:Key="Mute">#484F58</Color>

    <Color x:Key="Accent">#FFFFFF</Color>
    <Color x:Key="AccentActive">#58A6FF</Color>
    <Color x:Key="Error">#F85149</Color>
    <Color x:Key="Warning">#D29922</Color>
    <Color x:Key="Success">#3FB950</Color>

    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#000000</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="CanvasBrush" Color="{StaticResource Canvas}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}" />
    <SolidColorBrush x:Key="HairlineBrush" Color="{StaticResource Hairline}" />
    <SolidColorBrush x:Key="OnCanvasBrush" Color="{StaticResource OnCanvas}" />
    <SolidColorBrush x:Key="AccentActiveBrush" Color="{StaticResource AccentActive}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource Error}" />
</ResourceDictionary>