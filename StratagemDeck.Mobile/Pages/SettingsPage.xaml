<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StratagemDeck.Mobile.ViewModels"
             xmlns:conv="clr-namespace:StratagemDeck.Mobile.Converters"
             x:Class="StratagemDeck.Mobile.Pages.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="Settings"
             Shell.NavBarIsVisible="False"
             BackgroundColor="{StaticResource Canvas}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <conv:BoolToColorConverter x:Key="BoolToColor" />
            <conv:InverseBoolConverter x:Key="InverseBool" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="12" Padding="16" MaximumWidthRequest="500">

            <Border BackgroundColor="{StaticResource Surface}"
                    Stroke="{StaticResource Hairline}"
                    StrokeShape="RoundRectangle 12"
                    Padding="14">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <Border BackgroundColor="{Binding IsConnected, Converter={StaticResource BoolToColor}}"
                             WidthRequest="14" HeightRequest="14"
                             StrokeShape="RoundRectangle 7"
                             Stroke="Transparent"
                             VerticalOptions="Center" />
                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                        <Label Text="Connection"
                               FontSize="18"
                               TextColor="{StaticResource OnCanvas}"
                               FontAttributes="Bold" />
                        <Label Text="{Binding ConnectedServer}"
                               FontSize="14"
                               TextColor="{StaticResource Body}" />
                        <Label Text="{Binding CurrentPin, StringFormat='PIN: {0}'}"
                               FontSize="12"
                               TextColor="{StaticResource Mute}" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <Label Text="{Binding Status}"
                   TextColor="{StaticResource Body}"
                   FontSize="12"
                   HorizontalOptions="Center" />

            <Button Text="Scan QR Code"
                    FontSize="15"
                    BackgroundColor="{StaticResource Surface}"
                    TextColor="{StaticResource OnCanvas}"
                    CornerRadius="999"
                    HeightRequest="50"
                    Command="{Binding OpenQrScannerCommand}" />

            <Label Text="Discovered Servers"
                   FontSize="14"
                   TextColor="{StaticResource Body}"
                   FontAttributes="Bold"
                   IsVisible="{Binding IsScanning}" />

            <VerticalStackLayout Spacing="6"
                                 IsVisible="{Binding IsScanning}"
                                 BindableLayout.ItemsSource="{Binding DiscoveredServers}">
                <BindableLayout.ItemTemplate>
                    <DataTemplate x:DataType="x:Object">
                        <Border BackgroundColor="{StaticResource Surface}"
                                Stroke="{StaticResource Hairline}"
                                StrokeShape="RoundRectangle 8"
                                Padding="10"
                                Margin="0,2">
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                                <VerticalStackLayout>
                                    <Label Text="{Binding PcName}"
                                           FontSize="14"
                                           TextColor="{StaticResource OnCanvas}" />
                                    <Label Text="{Binding IpAddress}"
                                           FontSize="11"
                                           TextColor="{StaticResource Mute}" />
                                </VerticalStackLayout>
                                <Button Grid.Column="1"
                                        Text="Connect"
                                        FontSize="12"
                                        BackgroundColor="{StaticResource SurfaceSoft}"
                                        TextColor="{StaticResource OnCanvas}"
                                        CornerRadius="999"
                                        HeightRequest="36"
                                        Padding="14,0"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SettingsViewModel}}, Path=ConnectToServerCommand}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>

            <Button Text="Toggle Manual Entry"
                    FontSize="13"
                    BackgroundColor="{StaticResource Surface}"
                    TextColor="{StaticResource Body}"
                    CornerRadius="999"
                    Command="{Binding ToggleManualEntryCommand}" />

            <VerticalStackLayout Spacing="8"
                                 IsVisible="{Binding ShowManualEntry}">
                <Entry Placeholder="Server IP (e.g. 192.168.1.100)"
                       Text="{Binding ManualIp}"
                       TextColor="{StaticResource OnCanvas}"
                       PlaceholderColor="{StaticResource Mute}"
                       BackgroundColor="{StaticResource Surface}"
                       FontSize="14"
                       Keyboard="Telephone" />
                <Entry Placeholder="PIN (4 digits)"
                       Text="{Binding PinEntry}"
                       TextColor="{StaticResource OnCanvas}"
                       PlaceholderColor="{StaticResource Mute}"
                       BackgroundColor="{StaticResource Surface}"
                       FontSize="14"
                       MaxLength="4"
                       Keyboard="Numeric" />
                <Button Text="Connect"
                        FontSize="14"
                        BackgroundColor="{StaticResource SurfaceSoft}"
                        TextColor="{StaticResource OnCanvas}"
                        CornerRadius="999"
                        HeightRequest="44"
                        Command="{Binding ConnectManualCommand}" />
            </VerticalStackLayout>

            <Button Text="Rescan"
                    FontSize="14"
                    BackgroundColor="{StaticResource Surface}"
                    TextColor="{StaticResource OnCanvas}"
                    CornerRadius="999"
                    HeightRequest="44"
                    Command="{Binding StartScanCommand}"
                    IsVisible="{Binding IsScanning, Converter={StaticResource InverseBool}}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
