<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:HD2Companion.Mobile.ViewModels"
             xmlns:conv="clr-namespace:HD2Companion.Mobile.Converters"
             x:Class="HD2Companion.Mobile.Pages.SettingsPage"
             x:DataType="vm:SettingsViewModel"
             Title="Settings"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#1A1A2E">

    <ContentPage.Resources>
        <ResourceDictionary>
            <conv:BoolToColorConverter x:Key="BoolToColor" />
            <conv:InverseBoolConverter x:Key="InverseBool" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="12" Padding="16" MaximumWidthRequest="500">

            <!-- Connection Status -->
            <Border BackgroundColor="#16213E"
                    Stroke="#30363D"
                    StrokeShape="RoundRectangle 10"
                    Padding="14">
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                    <Border BackgroundColor="{Binding IsConnected, Converter={StaticResource BoolToColor}}"
                             WidthRequest="14" HeightRequest="14"
                             StrokeShape="RoundRectangle 7"
                             Stroke="Transparent"
                             VerticalOptions="Center" />
                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                        <Label Text="Connection"
                               FontSize="18"
                               TextColor="White"
                               FontAttributes="Bold" />
                        <Label Text="{Binding ConnectedServer}"
                               FontSize="14"
                               TextColor="#AAAAAA" />
                        <Label Text="{Binding CurrentPin, StringFormat='PIN: {0}'}"
                               FontSize="12"
                               TextColor="#666666" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- Status -->
            <Label Text="{Binding Status}"
                   TextColor="#AAAAAA"
                   FontSize="12"
                   HorizontalOptions="Center" />

            <!-- QR Scan Button -->
            <Button Text="Scan QR Code"
                    FontSize="15"
                    BackgroundColor="#0F3460"
                    TextColor="White"
                    CornerRadius="10"
                    HeightRequest="50"
                    Command="{Binding OpenQrScannerCommand}" />

            <!-- Discovered Servers -->
            <Label Text="Discovered Servers"
                   FontSize="14"
                   TextColor="#888"
                   FontAttributes="Bold"
                   IsVisible="{Binding IsScanning}" />

            <CollectionView ItemsSource="{Binding DiscoveredServers}"
                            SelectionMode="None"
                            HeightRequest="150"
                            IsVisible="{Binding IsScanning}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="x:Object">
                        <Border BackgroundColor="#16213E"
                                Stroke="#0F3460"
                                StrokeShape="RoundRectangle 8"
                                Padding="10"
                                Margin="0,2">
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10">
                                <VerticalStackLayout>
                                    <Label Text="{Binding PcName}"
                                           FontSize="14"
                                           TextColor="White" />
                                    <Label Text="{Binding IpAddress}"
                                           FontSize="11"
                                           TextColor="#666" />
                                </VerticalStackLayout>
                                <Button Grid.Column="1"
                                        Text="Connect"
                                        FontSize="12"
                                        BackgroundColor="#0F3460"
                                        TextColor="White"
                                        CornerRadius="6"
                                        HeightRequest="36"
                                        Padding="14,0"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SettingsViewModel}}, Path=ConnectToServerCommand}"
                                        CommandParameter="{Binding .}" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Manual Entry Section -->
            <Grid ColumnDefinitions="*,Auto"
                  IsVisible="{Binding ShowManualEntry, Converter={StaticResource InverseBool}, Converter={StaticResource InverseBool}}">
                <Label Text="Manual Connection"
                       FontSize="14"
                       TextColor="#888"
                       FontAttributes="Bold"
                       VerticalOptions="Center" />
            </Grid>

            <Button Text="{Binding ShowManualEntry, StringFormat='{0} Manual Entry'}"
                    FontSize="13"
                    BackgroundColor="#16213E"
                    TextColor="#AAAAAA"
                    CornerRadius="8"
                    Command="{Binding ToggleManualEntryCommand}" />

            <VerticalStackLayout Spacing="8"
                                 IsVisible="{Binding ShowManualEntry}">
                <Entry Placeholder="Server IP (e.g. 192.168.1.100)"
                       Text="{Binding ManualIp}"
                       TextColor="White"
                       PlaceholderColor="#555"
                       BackgroundColor="#16213E"
                       FontSize="14"
                        Keyboard="Telephone" />
                <Entry Placeholder="PIN (4 digits)"
                       Text="{Binding PinEntry}"
                       TextColor="White"
                       PlaceholderColor="#555"
                       BackgroundColor="#16213E"
                       FontSize="14"
                       MaxLength="4"
                       Keyboard="Numeric"
                       IsPassword="False" />
                <Button Text="Connect"
                        FontSize="14"
                        BackgroundColor="#0F3460"
                        TextColor="White"
                        CornerRadius="8"
                        HeightRequest="44"
                        Command="{Binding ConnectManualCommand}" />
            </VerticalStackLayout>

            <!-- Action Buttons -->
            <Button Text="Rescan"
                    FontSize="14"
                    BackgroundColor="#16213E"
                    TextColor="White"
                    CornerRadius="8"
                    HeightRequest="44"
                    Command="{Binding StartScanCommand}"
                    IsVisible="{Binding IsScanning, Converter={StaticResource InverseBool}}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
