<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StratagemDeck.Mobile.ViewModels"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             x:Class="StratagemDeck.Mobile.Pages.QrScanPage"
             x:DataType="vm:QrScanViewModel"
             Title="Scan QR"
             Shell.NavBarIsVisible="False"
             BackgroundColor="Black">

    <Grid RowDefinitions="*,Auto" Padding="0">

        <zxing:CameraBarcodeReaderView Grid.Row="0"
                                        x:Name="BarcodeView"
                                        IsDetecting="{Binding IsScanning}" />

        <VerticalStackLayout Grid.Row="1"
                             Padding="16,8"
                             BackgroundColor="{StaticResource Canvas}"
                             Spacing="8">
            <Label Text="{Binding Status}"
                   TextColor="{StaticResource Body}"
                   FontSize="14"
                   HorizontalOptions="Center" />
            <Button Text="Cancel"
                     FontSize="14"
                     BackgroundColor="{StaticResource Error}"
                     TextColor="{StaticResource OnCanvas}"
                     CornerRadius="999"
                     HeightRequest="40"
                     Clicked="OnCancel" />
        </VerticalStackLayout>

    </Grid>
</ContentPage>
