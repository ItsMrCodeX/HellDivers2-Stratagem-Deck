<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="HD2Companion.Mobile.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:HD2Companion.Mobile.Pages"
    Shell.FlyoutBehavior="Disabled"
    Shell.TabBarBackgroundColor="#0D1117"
    Shell.TabBarTitleColor="#E2E2E2"
    Shell.TabBarUnselectedColor="#555555"
    Shell.BackgroundColor="#0D1117">

    <TabBar>
        <ShellContent
            Title="Game"
            ContentTemplate="{DataTemplate pages:GamePage}"
            Route="game" />
        <ShellContent
            Title="Setup"
            ContentTemplate="{DataTemplate pages:SetupPage}"
            Route="setup" />
        <ShellContent
            Title="Settings"
            ContentTemplate="{DataTemplate pages:SettingsPage}"
            Route="settings" />
    </TabBar>

</Shell>
